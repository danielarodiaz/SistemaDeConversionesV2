# ============================================================
# VARIABLES DE ENTORNO - SistemaDeConversiones_V2
# ============================================================
# Copiá este archivo como .env y completá los valores reales.
# NUNCA subas el archivo .env a Git.
# ============================================================

# ── ENTORNO LOCAL (Docker / SQL Auth) ────────────────────────
# DB_AUTH_TYPE=SQL
# DB_HOST=127.0.0.1
# DB_PORT=1433
# DB_USER=sa
# DB_PASSWORD=tu_password_aqui
# DB_NAME=Conversor_DB

# ── ENTORNO SERVIDOR (Windows Auth / SQLEXPRESS) ─────────────
# DB_AUTH_TYPE=WINDOWS
# DB_HOST=DB2\SQLEXPRESS
# DB_PORT=     <- no se usa en Windows Auth, se puede dejar vacío
# DB_USER=     <- no se usa en Windows Auth
# DB_PASSWORD= <- no se usa en Windows Auth
# DB_NAME=Conversor_DB

# ── VALORES ACTIVOS (descomentá el bloque que corresponda) ────
DB_AUTH_TYPE=SQL
DB_HOST=127.0.0.1
DB_PORT=1433
DB_USER=sa
DB_PASSWORD=
DB_NAME=Conversor_DB

# --- CEGID (SQL Server externo) ---
CEGID_SERVER=<ip_o_hostname>,<puerto>
CEGID_DATABASE=<nombre_base_de_datos>
CEGID_USERNAME=<usuario>
CEGID_PASSWORD=<contraseña>

# --- Flask ---
FLASK_SECRET_KEY=
FLASK_ENV=production
BACKEND_PORT=5000

# --- URL del Backend (usada por el frontend Streamlit) ---
# En desarrollo local:   http://localhost:5000
# En producción (ngrok): https://<subdominio>.ngrok-free.app
BACKEND_URL=http://localhost:5000
