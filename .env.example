# ============================================================
# VARIABLES DE ENTORNO - SistemaDeConversiones_V2
# ============================================================
# Copiá este archivo como .env y completá los valores reales.
# NUNCA subas el archivo .env a Git.
# ============================================================

# --- Base de Datos Local (SQL Server) ---
DB_USER=sa
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=1433
DB_NAME=Conversor_DB

# --- CEGID (SQL Server externo) ---
CEGID_SERVER=
CEGID_DATABASE=
CEGID_USERNAME=
CEGID_PASSWORD=

# --- Flask ---
FLASK_SECRET_KEY=
FLASK_ENV=production
# Puerto en el que corre el backend Flask
BACKEND_PORT=5000

# --- URL del Backend (usada por el frontend Streamlit) ---
# En desarrollo: http://localhost:5000
# En producción: http://<ip-del-servidor>:<puerto>
BACKEND_URL=http://localhost:5000
